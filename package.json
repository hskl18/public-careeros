{
  "name": "careeros",
  "version": "0.1.0",
  "description": "CareerOS public hackathon demo: a Gemma-powered recruiting inbox pipeline with optional Gmail sync and review gates.",
  "keywords": [
    "careeros",
    "careeroc",
    "gemma",
    "ollama",
    "gmail",
    "job-search",
    "multi-agent",
    "nextjs",
    "kaggle"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "homepage": "https://github.com/hskl18/public-careeros#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hskl18/public-careeros.git"
  },
  "bugs": {
    "url": "https://github.com/hskl18/public-careeros/issues"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "smoke:browser": "tsx tools/browser-smoke.ts",
    "smoke:ollama": "tsx tools/ollama-cloud-smoke.ts",
    "release:check": "bash scripts/public-safety-check.sh && pnpm check && pnpm test && pnpm build && pnpm smoke:browser && pnpm smoke:ollama && git diff --check",
    "ci": "pnpm check && pnpm test && pnpm build"
  },
  "dependencies": {
    "next": "^15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "22.15.30",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.2"
  }
}
