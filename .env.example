# Public demo example only. Do not commit real secrets.

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local state
CAREEROS_DATA_DIR=.careeros-data
CAREEROS_PERSISTENCE=json
# Optional explicit key for local encrypted token envelopes.
CAREEROS_TOKEN_SECRET=

# Optional Ollama Cloud / Gemma. Disabled by default so first run needs no model setup or API cost.
CAREEROS_OLLAMA_ENABLED=false
CAREEROS_OLLAMA_BASE_URL=https://ollama.com
CAREEROS_GEMMA_MODEL=gemma4:31b
OLLAMA_API_KEY=

# Optional Gmail readonly sync. The demo works without it, but this lets
# CareerOS pull recent recruiting mail into the Ollama Cloud/Gemma review pipeline.
CAREEROS_GMAIL_CONNECTOR_ENABLED=false
CAREEROS_GMAIL_CLIENT_ID=
CAREEROS_GMAIL_CLIENT_SECRET=
CAREEROS_GMAIL_REDIRECT_URI=http://localhost:3000/api/connectors/gmail/callback
CAREEROS_GMAIL_QUERY='newer_than:90d (recruiter OR application OR assessment OR interview OR "next steps" OR offer OR OA)'
CAREEROS_GMAIL_MAX_RESULTS=10
