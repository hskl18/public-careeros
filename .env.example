# Public local-first example only. Do not commit real secrets.

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local state
CAREEROS_DATA_DIR=.careeros-data
CAREEROS_PERSISTENCE=sqlite

# Optional Ollama/Gemma. Disabled by default so first run needs no model setup.
CAREEROS_OLLAMA_ENABLED=false
CAREEROS_OLLAMA_BASE_URL=http://localhost:11434
CAREEROS_GEMMA_MODEL=gemma3:4b

# Optional connector placeholders. The local dashboard works without them.
CAREEROS_GMAIL_CONNECTOR_ENABLED=false
CAREEROS_GMAIL_CLIENT_ID=
CAREEROS_GMAIL_CLIENT_SECRET=
